# === LLM Providers ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# === Agent Tools ===
TAVILY_API_KEY=tvly-...
E2B_API_KEY=e2b_...

# === Memory / Databases ===
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/neuroagent
REDIS_URL=redis://localhost:6379/0
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=neuroagent-memory
PINECONE_ENVIRONMENT=us-east-1-aws

# === Auth ===
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# === LangSmith Tracing ===
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="NeuroAgent"

# === Backend Config ===
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# === Docker image source (used by docker-compose.yml) ===
# Docker Hub namespace for pre-built images. Override if you're publishing
# your own fork.
DOCKER_NAMESPACE=amunim12
# Image tag to pull. 'latest' for main, a semver (e.g. 1.0.0), or
# 'sha-<shortsha>' for a specific commit.
IMAGE_TAG=latest

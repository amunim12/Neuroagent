# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Agent Tools
TAVILY_API_KEY=
E2B_API_KEY=

# Databases
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/neuroagent
REDIS_URL=redis://localhost:6379/0
PINECONE_API_KEY=
PINECONE_INDEX_NAME=neuroagent-memory
PINECONE_ENVIRONMENT=us-east-1-aws

# Auth
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:3002","http://localhost:3003"]
ENVIRONMENT=development

# Default model (groq-llama3 | gpt-4o | claude-sonnet)
DEFAULT_AGENT_MODEL=groq-llama3

# LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=neuroagent
